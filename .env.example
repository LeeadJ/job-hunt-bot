# ============================================
# Job Hunt Bot — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (so only YOU can use the bot)
# Send /start to @userinfobot to find yours
TELEGRAM_OWNER_ID=your_telegram_user_id

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Sheet tab names (must match your spreadsheet exactly)
SHEET_APPLICATIONS=Applications
SHEET_NETWORKING=Networking

# Scraping config
SCRAPE_DELAY_MS=3000
MAX_SCRAPES_PER_HOUR=30

# Reminder config
FOLLOWUP_DAYS=7
WEEKLY_DIGEST_DAY=0
WEEKLY_DIGEST_HOUR=10

# Optional: RapidAPI LinkedIn Jobs (more reliable than scraping)
# Sign up at https://rapidapi.com/rockapis-rockapis-default/api/linkedin-api8
# RAPIDAPI_KEY=your_key_here
